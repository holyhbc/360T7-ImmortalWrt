CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_qihoo_360t7=y

# ===== 基础 =====
CONFIG_DEVEL=y
CONFIG_TOOLCHAINOPTS=y
CONFIG_BUSYBOX_CUSTOM=y

# ===== 编译器 =====
CONFIG_GCC_USE_VERSION_12=y
CONFIG_GCC_VERSION="12.3.0"

# ===== 内核关键 =====
CONFIG_KERNEL_DEVMEM=y
CONFIG_KERNEL_CGROUP_DEVICE=y
CONFIG_KERNEL_CGROUP_FREEZER=y

# ===== WiFi（闭源核心）=====
CONFIG_PACKAGE_kmod-mt_wifi=y
CONFIG_MTK_MT_WIFI=y
CONFIG_MTK_WIFI_DRIVER=y
CONFIG_MTK_MT_AP_SUPPORT=y

CONFIG_PACKAGE_mtwifi-cfg=y
CONFIG_PACKAGE_luci-app-mtwifi-cfg=y

# ⭐ 必须有（你之前缺的）
# CONFIG_PACKAGE_wpad-openssl=y

# ===== WiFi兼容 =====
CONFIG_PACKAGE_kmod-cfg80211=y
CONFIG_PACKAGE_kmod-mac80211=y
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_iw=y

# ===== MTK硬件加速 =====
CONFIG_PACKAGE_kmod-mediatek_hnat=y
CONFIG_MTK_FAST_NAT_SUPPORT=y
CONFIG_MTK_WHNAT_SUPPORT=y

# ===== 网络核心 =====
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iptables-nft=y

CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_iptables-mod-nat-extra=y
CONFIG_PACKAGE_iptables-mod-filter=y

# ===== 翻墙组件 =====
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_cloudflared=y
CONFIG_PACKAGE_dns2socks=y
CONFIG_PACKAGE_chinadns-ng=y
CONFIG_PACKAGE_microsocks=y

CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-app-passwall=y

# ===== LuCI =====
CONFIG_PACKAGE_luci-theme-argon=y

# ===== 系统工具（精简版）=====
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-base64=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_curl=y
CONFIG_LIBCURL_HTTP=y
CONFIG_LIBCURL_OPENSSL=y

CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_htop=y

# ===== SSH =====
CONFIG_PACKAGE_openssh-keygen=y
CONFIG_PACKAGE_openssh-sftp-server=y

# ===== 存储 =====
CONFIG_PACKAGE_blockd=y
CONFIG_PACKAGE_kmod-fs-vfat=y

# ===== ZRAM（内存优化）=====
CONFIG_PACKAGE_kmod-zram=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_ZRAM_DEF_COMP_LZORLE=y

# ===== 证书 =====
CONFIG_PACKAGE_ca-certificates=y

# ===== 其他 =====
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_resolveip=y
CONFIG_PACKAGE_terminfo=y

# ===== LuCI 插件 =====
CONFIG_PACKAGE_luci-app-cloudflared=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-wrtbwmon=y

# ===== 禁用冲突项 =====
# CONFIG_PACKAGE_kmod-mt76 is not set

# ===== 删除内存大户 =====
# ❌ Ruby 全部移除
# ❌ 多余 iptables 模块移除
# ❌ tcpdump / tcping 移除
