CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_mediatek_filogic_DEVICE_qihoo_360t7=y

# ===== 基础 =====
# CONFIG_DEVEL is not set
# CONFIG_TOOLCHAINOPTS is not set

# ===== MTK核心（必须）=====
CONFIG_MTK_MT_WIFI=y
CONFIG_MTK_MT_AP_SUPPORT=y
CONFIG_MTK_WIFI_MODE_AP=y
CONFIG_PACKAGE_kmod-mtk-warp=n

CONFIG_PACKAGE_kmod-conninfra=y
CONFIG_CONNINFRA_AUTO_UP=y
CONFIG_CONNINFRA_EMI_SUPPORT=y
CONFIG_MTK_CONNINFRA_APSOC=y

CONFIG_PACKAGE_kmod-mt_wifi=y
CONFIG_PACKAGE_hostapd-common=y

# ✅ 稳定优先（不要换basic）
CONFIG_PACKAGE_wpad-openssl=y
CONFIG_PACKAGE_wireless-regdb=y

# ===== 网络 =====
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
CONFIG_PACKAGE_odhcp6c=y

CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_ipset=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_kmod-nft-compat=y
CONFIG_PACKAGE_kmod-tun=y

# ===== 系统 =====
CONFIG_PACKAGE_base-files=y
CONFIG_PACKAGE_busybox=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_dropbear=y
CONFIG_PACKAGE_fstools=y
CONFIG_PACKAGE_logd=y
CONFIG_PACKAGE_mtd=y
CONFIG_PACKAGE_opkg=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_procd-ujail=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_ubus=y
CONFIG_PACKAGE_ubusd=y
CONFIG_PACKAGE_uclient-fetch=y
CONFIG_PACKAGE_urngd=y

# ===== LuCI（稳定版）=====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-light=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-lib-base=y
CONFIG_PACKAGE_luci-lib-ipkg=y

# 👉 软件中心（可选但建议）
CONFIG_PACKAGE_luci-app-package-manager=y

# ===== 代理 =====
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_sing-box=y

# ===== Cloudflare（可用）=====
CONFIG_PACKAGE_cloudflared=y
CONFIG_PACKAGE_luci-app-cloudflared=y

# ===== 工具（适中）=====
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_nano=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y

# ===== 存储 =====
CONFIG_PACKAGE_kmod-nls-base=y
CONFIG_PACKAGE_kmod-nls-utf8=y

# ===== ZRAM（关键）=====
CONFIG_PACKAGE_zram-swap=y
CONFIG_ZRAM_DEF_COMP_LZORLE=y

# ===== 硬件 =====
CONFIG_PACKAGE_kmod-gpio-button-hotplug=y
CONFIG_PACKAGE_kmod-leds-gpio=y

# ===== NAT优化 =====
CONFIG_PACKAGE_kmod-nf-nathelper=y
CONFIG_PACKAGE_kmod-nf-nathelper-extra=y
CONFIG_PACKAGE_kmod-nft-offload=y

# ===== PPP =====
CONFIG_PACKAGE_ppp=y
CONFIG_PACKAGE_ppp-mod-pppoe=y

# ==============================
# ❌ 稳定版也要删的（关键）
# ==============================

# ❌ WARP（已确认不兼容）
CONFIG_PACKAGE_kmod-warp=n
CONFIG_MTK_WARP_V2=n
CONFIG_WARP_DBG_SUPPORT=n

# ❌ 双代理（避免冲突）
# CONFIG_PACKAGE_luci-app-passwall is not set

# ❌ 代理杂项
# CONFIG_PACKAGE_dns2socks is not set
# CONFIG_PACKAGE_ipt2socks is not set
# CONFIG_PACKAGE_microsocks is not set
# CONFIG_PACKAGE_chinadns-ng is not set

# ❌ 内存大户
# CONFIG_PACKAGE_ruby is not set

# ❌ 无用组件
# CONFIG_PACKAGE_coreutils is not set
# CONFIG_PACKAGE_bash is not set
# CONFIG_PACKAGE_bridger is not set

# ❌ 错误WiFi体系
# CONFIG_PACKAGE_kmod-mt7915e is not set
# CONFIG_PACKAGE_kmod-mt7981-firmware is not set
# CONFIG_PACKAGE_mt7981-wo-firmware is not set
